---
interface Props {
  title?: string
  subtitle?: string
  id?: string
}

const {
  title = 'Une idée d\'outil à transformer en app ?',
  subtitle = 'Parlons-en. Je prototypise vite, je livre propre.',
  id = 'contact',
} = Astro.props
---

<section {id} class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-grid opacity-40" />
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-indigo-500/3 to-transparent" />

  <div class="relative max-w-4xl mx-auto px-6 text-center">
    <div class="p-px rounded-2xl bg-gradient-to-br from-indigo-500/20 via-violet-500/10 to-transparent">
      <div class="rounded-2xl bg-zinc-950/80 backdrop-blur-sm p-12 md:p-16 flex flex-col items-center gap-8">
        <!-- Icon -->
        <div class="w-16 h-16 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>

        <div class="flex flex-col gap-4">
          <h2 class="text-3xl md:text-4xl font-bold text-zinc-100">
            {title}
          </h2>
          <p class="text-zinc-400 text-lg max-w-md mx-auto leading-relaxed">
            {subtitle}
          </p>
        </div>

        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="mailto:contact@nocodetools.fr"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-indigo-500 hover:bg-indigo-400 text-white font-semibold transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/25 hover:-translate-y-0.5"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Me contacter
          </a>
          <a
            href="/apps"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-white/5 hover:bg-white/10 text-zinc-300 hover:text-white font-semibold transition-all duration-200 border border-white/8 hover:border-white/16 hover:-translate-y-0.5"
          >
            Voir les apps
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
