---
import type { App } from '../types/app'
import TechBadge from './TechBadge.astro'
import StatusBadge from './StatusBadge.astro'

interface Props {
  app: App
  compact?: boolean
}

const { app, compact = false } = Astro.props
---

<article
  class="group relative flex flex-col rounded-xl border border-white/8 bg-zinc-900/50 overflow-hidden card-hover"
  data-category={app.category}
  data-stack={app.stack.join(',')}
  data-title={`${app.title} ${app.tagline} ${app.stack.join(' ')}`}
>
  <!-- Screenshot -->
  <a href={`/apps/${app.slug}`} class="block relative overflow-hidden aspect-video bg-zinc-950 shrink-0">
    <img
      src={app.screenshots.main}
      alt={`${app.title} screenshot`}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
    />
    <!-- Status badge overlay -->
    <div class="absolute top-3 right-3">
      <StatusBadge status={app.status} size="sm" />
    </div>
    <!-- Hover overlay -->
    <div class="absolute inset-0 bg-indigo-500/0 group-hover:bg-indigo-500/5 transition-colors duration-300" />
  </a>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-4">
    <!-- Category + title -->
    <div class="flex flex-col gap-1">
      <span class="text-xs font-semibold text-indigo-400 tracking-widest uppercase">
        {app.category}
      </span>
      <a href={`/apps/${app.slug}`} class="block group/title">
        <h3 class="text-lg font-bold text-zinc-100 group-hover/title:text-white transition-colors leading-snug">
          {app.title}
        </h3>
      </a>
      {!compact && (
        <p class="text-sm text-zinc-500 leading-relaxed line-clamp-2 mt-1">
          {app.tagline}
        </p>
      )}
    </div>

    <!-- Stack -->
    <div class="flex flex-wrap gap-1.5 mt-auto">
      {app.stack.slice(0, 4).map(tech => <TechBadge tech={tech} />)}
      {app.stack.length > 4 && (
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs text-zinc-600">
          +{app.stack.length - 4}
        </span>
      )}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 pt-3 border-t border-white/5">
      {app.links.github && (
        <a
          href={app.links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs text-zinc-400 hover:text-zinc-100 px-3 py-1.5 rounded-lg hover:bg-white/5 transition-all border border-transparent hover:border-white/10"
          onclick="event.stopPropagation()"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
      )}
      {app.links.demo && (
        <a
          href={app.links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs text-indigo-400 hover:text-indigo-300 px-3 py-1.5 rounded-lg hover:bg-indigo-500/10 transition-all border border-transparent hover:border-indigo-500/20"
          onclick="event.stopPropagation()"
        >
          Démo
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
      <a
        href={`/apps/${app.slug}`}
        class="ml-auto flex items-center gap-1 text-xs text-zinc-600 hover:text-zinc-300 transition-colors"
      >
        Voir
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
