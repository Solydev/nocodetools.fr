---
const year = new Date().getFullYear()
---

<footer class="border-t border-white/5 mt-24">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo & tagline -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-6 h-6 rounded-md bg-indigo-500 flex items-center justify-center text-white text-xs font-bold group-hover:bg-indigo-400 transition-colors">
            N
          </div>
          <span class="font-semibold text-zinc-300 text-sm tracking-tight group-hover:text-white transition-colors">
            nocodetools<span class="text-zinc-600">.fr</span>
          </span>
        </a>
        <p class="text-xs text-zinc-600 text-center md:text-left">
          Des apps utiles, propres et rapidement prototypées.
        </p>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-zinc-500">
        <a href="/apps" class="hover:text-zinc-300 transition-colors">Apps</a>
        <a href="https://github.com/solydev" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-300 transition-colors">GitHub</a>
        <a href="mailto:florian@solydev.com" class="hover:text-zinc-300 transition-colors">Contact</a>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-white/5 flex justify-center">
      <p class="text-xs text-zinc-700">
        © {year} nocodetools.fr — Tous droits réservés
      </p>
    </div>
  </div>
</footer>
