---
import type { AppStatus } from '../types/app'

interface Props {
  status: AppStatus
  size?: 'sm' | 'md'
}

const { status, size = 'md' } = Astro.props

const config: Record<AppStatus, { dot: string; text: string; bg: string; border: string }> = {
  'Live': {
    dot: 'bg-emerald-400',
    text: 'text-emerald-400',
    bg: 'bg-emerald-400/10',
    border: 'border-emerald-400/20',
  },
  'Prototype': {
    dot: 'bg-amber-400',
    text: 'text-amber-400',
    bg: 'bg-amber-400/10',
    border: 'border-amber-400/20',
  },
  'Private': {
    dot: 'bg-zinc-400',
    text: 'text-zinc-400',
    bg: 'bg-zinc-400/10',
    border: 'border-zinc-400/20',
  },
  'In Progress': {
    dot: 'bg-blue-400',
    text: 'text-blue-400',
    bg: 'bg-blue-400/10',
    border: 'border-blue-400/20',
  },
}

const c = config[status]
const sizeClass = size === 'sm' ? 'text-xs px-2 py-0.5' : 'text-xs px-2.5 py-1'
---

<span class:list={[
  'inline-flex items-center gap-1.5 rounded-full font-medium border',
  c.bg, c.text, c.border, sizeClass,
]}>
  <span class:list={['w-1.5 h-1.5 rounded-full animate-pulse', c.dot]} />
  {status}
</span>
