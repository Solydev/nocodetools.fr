---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Page introuvable" description="Cette page n'existe pas.">
  <div class="min-h-screen flex items-center justify-center relative overflow-hidden">
    <div class="absolute inset-0 bg-grid opacity-40" />
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-96 h-96 bg-indigo-500/8 rounded-full blur-3xl" />

    <div class="relative flex flex-col items-center gap-8 text-center px-6 py-24">
      <!-- 404 -->
      <div class="relative">
        <span class="text-[10rem] md:text-[14rem] font-extrabold leading-none text-zinc-900 select-none">
          404
        </span>
        <span class="absolute inset-0 flex items-center justify-center text-[10rem] md:text-[14rem] font-extrabold leading-none gradient-text-accent opacity-10 select-none blur-sm">
          404
        </span>
      </div>

      <!-- Message -->
      <div class="flex flex-col gap-3 -mt-8">
        <h1 class="text-2xl md:text-3xl font-bold text-zinc-200">
          Cette page n'existe pas
        </h1>
        <p class="text-zinc-500 max-w-sm leading-relaxed">
          Elle a peut-être été déplacée, supprimée, ou vous avez suivi un lien invalide.
        </p>
      </div>

      <!-- CTA -->
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-500 hover:bg-indigo-400 text-white font-semibold text-sm transition-all duration-200 hover:shadow-lg hover:shadow-indigo-500/25 hover:-translate-y-0.5"
        >
          Retour à l'accueil
        </a>
        <a
          href="/apps"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 text-zinc-300 hover:text-white font-semibold text-sm transition-all border border-white/8 hover:border-white/16 hover:-translate-y-0.5"
        >
          Voir les apps
        </a>
      </div>
    </div>
  </div>
</Layout>
